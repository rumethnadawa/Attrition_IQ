# =============================================================
#  AttritionIQ — .gitignore
# =============================================================

# Environment & Secrets (NEVER commit these)
.env
*.pem
*.key
*.p12
*.pfx

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so
env/
venv/
.venv/
.Python

# Jupyter Notebooks
.ipynb_checkpoints/

# Model artifacts (stored in S3, downloaded at runtime)
models/
*.pkl
*.joblib

# Output charts & CSV (generated by pipeline, stored in S3)
outputs/

# Dataset (stored in S3)
*.csv

# Large archives & packaging leftovers
*.tar.gz
*.zip
*.gz

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# AWS CDK / SAM
cdk.out/
.aws-sam/

# Logs
*.log
